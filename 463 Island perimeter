int islandPerimeter(int** grid, int gridSize, int* gridColSize) {
    int r = gridSize;
    int c = gridColSize[0];
    int p = 0;

    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            if (grid[i][j] == 1) {
                p = p + 4;

                if (i > 0 && grid[i - 1][j] == 1)
                    p = p - 2;
                if (j > 0 && grid[i][j - 1] == 1)
                    p = p - 2;
            }
        }
    }
    return p;
}
